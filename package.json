{
  "name": "tengah-helper",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "icons": "node scripts/generate-icons.mjs",
    "dev:functions": "wrangler pages dev dist --port 8788 --compatibility-date=2026-07-01",
    "deploy": "npm run build && wrangler pages deploy dist --project-name tengah-helper"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "sharp": "^0.34.2",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vite-plugin-pwa": "^1.0.1",
    "wrangler": "^4.22.0"
  }
}
